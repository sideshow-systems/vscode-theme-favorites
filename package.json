{
	"name": "vscode-theme-favorites",
	"displayName": "%displayName%",
	"publisher": "sideshow-systems",
	"repository": {
		"type": "git",
		"url": "https://github.com/sideshow-systems/vscode-theme-favorites"
	},
	"version": "1.3.1",
	"engines": {
		"vscode": "^1.60.0"
	},
	"categories": [
		"Themes"
	],
	"icon": "images/icon.png",
	"description": "%description%",
	"activationEvents": [
		"onCommand:themeFavorites.addFavorite",
		"onCommand:themeFavorites.removeFavorite",
		"onCommand:themeFavorites.chooseFavorite",
		"onCommand:themeFavorites.openTheme",
		"onCommand:themeFavorites.toggleFavorite",
		"onCommand:themeFavorites.refresh",
		"onView:theme-favorites-webview",
		"onView:theme-favorites-favorites"
	],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"themeFavorites.favorites": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%themeFavorites.favorites.description%",
					"scope": "application"
				}
			}
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "theme-favorites",
					"title": "%viewsContainers.title%",
					"icon": "resources/icon.svg"
				}
			]
		},
		"views": {
			"theme-favorites": [
				{ "id": "theme-favorites-favorites", "name": "%views.favorites.name%", "type": "webview" },
				{ "id": "theme-favorites-webview", "name": "%views.browse.name%", "type": "webview" }
			]
		},
		"commands": [
			{ "command": "themeFavorites.addFavorite", "title": "%commands.addFavorite.title%" },
			{ "command": "themeFavorites.removeFavorite", "title": "%commands.removeFavorite.title%" },
			{ "command": "themeFavorites.chooseFavorite", "title": "%commands.chooseFavorite.title%" },
			{ "command": "themeFavorites.openTheme", "title": "%commands.openTheme.title%" },
			{ "command": "themeFavorites.toggleFavorite", "title": "%commands.toggleFavorite.title%" },
			{ "command": "themeFavorites.refresh", "title": "%commands.refresh.title%" }
		],
		"menus": {
			"view/title": [
				{ "command": "themeFavorites.refresh", "when": "view == theme-favorites-webview", "group": "navigation" },
				{ "command": "themeFavorites.refresh", "when": "view == theme-favorites-favorites", "group": "navigation" }
			],
			"view/item/context": [
				{ "command": "themeFavorites.openTheme", "when": "view == theme-favorites-webview", "group": "navigation" },
				{ "command": "themeFavorites.addFavorite", "when": "view == theme-favorites-webview && viewItem == notFavorited", "group": "inline" },
				{ "command": "themeFavorites.removeFavorite", "when": "view == theme-favorites-webview && viewItem == favorited", "group": "inline" },
				{ "command": "themeFavorites.openTheme", "when": "view == theme-favorites-favorites", "group": "navigation" },
				{ "command": "themeFavorites.removeFavorite", "when": "view == theme-favorites-favorites && viewItem == favoriteItem", "group": "inline" }
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -w -p ./",
		"postinstall": "node ./node_modules/vscode/bin/install || true",
		"build-package": "npx vsce package"
	},
	"devDependencies": {
		"@types/node": "^18.0.0",
		"typescript": "^4.9.5",
		"vscode": "^1.1.37"
	}
}
